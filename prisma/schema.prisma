generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  REVIEWER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentBlockType {
  TEXT
  VIDEO
  FILE
  QUIZ
  EMBED
}

enum TestType {
  LESSON
  MODULE
  COURSE
  DIAGNOSTIC
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  REVIEWED
  RESUBMIT_REQUIRED
}

enum AccessType {
  LIFETIME
  TEMPORARY
}

enum AccessSource {
  PURCHASE
  ADMIN_GRANT
  FREE
  PROMO
}

enum OrderStatus {
  PENDING
  WAITING_CAPTURE
  SUCCEEDED
  CANCELED
  FAILED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

model User {
  id               String                 @id @default(cuid())
  email            String?                @unique
  passwordHash     String?
  displayName      String
  role             Role                   @default(USER)
  yandexId         String?                @unique
  telegramId       String?                @unique
  refreshTokenHash String?
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  accessGrants     AccessGrant[]
  testAttempts     TestAttempt[]
  submissions      AssignmentSubmission[]
  certificates     Certificate[]
  orders           Order[]
  ratingEvents     RatingEvent[]
  userRating       UserRating?
  eventLogs        EventLog[]
  issuedCertificates Certificate[]        @relation("CertificateIssuer")
  createdVersions  CourseVersion[]        @relation("CourseVersionCreator")
  lessonProgresses LessonProgress[]
}

model Course {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  description      String
  status           CourseStatus    @default(DRAFT)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  versions         CourseVersion[]
  currentVersionId String?
  currentVersion   CourseVersion?  @relation("CurrentCourseVersion", fields: [currentVersionId], references: [id])
  tests            Test[]
  assignments      Assignment[]
  certificates     Certificate[]
  accessGrants     AccessGrant[]
  orders           Order[]
}

model CourseVersion {
  id                 String       @id @default(cuid())
  courseId           String
  versionNumber      Int
  title              String
  description        String
  isPublished        Boolean      @default(false)
  freePreviewEnabled Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  createdById        String?
  course             Course       @relation(fields: [courseId], references: [id])
  createdBy          User?        @relation("CourseVersionCreator", fields: [createdById], references: [id])
  sections           Section[]
  tests              Test[]
  assignments        Assignment[]
  currentForCourse   Course[]     @relation("CurrentCourseVersion")

  @@unique([courseId, versionNumber])
}

model Section {
  id              String         @id @default(cuid())
  courseVersionId String
  title           String
  orderIndex      Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  courseVersion   CourseVersion  @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  modules         CourseModule[]

  @@unique([courseVersionId, orderIndex])
}

model CourseModule {
  id          String   @id @default(cuid())
  sectionId   String
  title       String
  description String
  orderIndex  Int
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  tests       Test[]

  @@unique([sectionId, orderIndex])
}

model Lesson {
  id          String         @id @default(cuid())
  moduleId    String
  title       String
  slug        String?
  markdownBody String        @default("")
  status      PublishStatus  @default(DRAFT)
  meta        Json?
  autosaveVersion Int        @default(1)
  orderIndex  Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  module      CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  contentBlocks ContentBlock[]
  tests       Test[]
  assignments Assignment[]
  versions    LessonVersion[]
  progresses  LessonProgress[]

  @@unique([moduleId, orderIndex])
}

model ContentBlock {
  id          String           @id @default(cuid())
  lessonId    String
  type        ContentBlockType
  orderIndex  Int
  title       String?
  body        String
  isFree      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lesson      Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, orderIndex])
}

model LessonVersion {
  id           String   @id @default(cuid())
  lessonId     String
  version      Int
  markdownBody String
  createdAt    DateTime @default(now())
  createdBy    String
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, version])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, completedAt])
}

model Test {
  id              String       @id @default(cuid())
  title           String
  type            TestType
  courseId        String?
  courseVersionId String?
  moduleId        String?
  lessonId        String?
  maxScore        Int          @default(100)
  passScore       Int          @default(70)
  shuffleQuestions Boolean     @default(true)
  shuffleAnswers   Boolean     @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  course          Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersion   CourseVersion? @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  module          CourseModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lesson          Lesson?      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions       TestQuestion[]
  attempts        TestAttempt[]

  @@index([type])
}

model TestQuestion {
  id          String       @id @default(cuid())
  testId       String
  prompt       String
  orderIndex   Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  test         Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers      TestAnswer[]
  attemptAnswers TestAttemptAnswer[]

  @@unique([testId, orderIndex])
}

model TestAnswer {
  id          String       @id @default(cuid())
  questionId  String
  text        String
  isCorrect   Boolean      @default(false)
  orderIndex  Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  question    TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptAnswers TestAttemptAnswer[]

  @@unique([questionId, orderIndex])
}

model TestAttempt {
  id            String               @id @default(cuid())
  testId         String
  userId         String
  score          Int
  passed         Boolean
  startedAt      DateTime             @default(now())
  completedAt    DateTime             @default(now())
  attemptAnswers TestAttemptAnswer[]
  test           Test                 @relation(fields: [testId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([testId, userId])
}

model TestAttemptAnswer {
  id            String       @id @default(cuid())
  attemptId      String
  questionId     String
  answerId       String?
  answerText     String?
  isCorrect      Boolean
  attempt        TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       TestQuestion @relation(fields: [questionId], references: [id])
  answer         TestAnswer?  @relation(fields: [answerId], references: [id])
}

model Assignment {
  id              String                 @id @default(cuid())
  title           String
  description     String
  maxScore        Int                    @default(100)
  courseId        String?
  courseVersionId String?
  lessonId        String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  course          Course?                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersion   CourseVersion?         @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  lesson          Lesson?                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions     AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String           @id @default(cuid())
  assignmentId  String
  userId        String
  content       String
  attachmentUrl String?
  status        SubmissionStatus @default(SUBMITTED)
  score         Int?
  feedback      String?
  reviewedAt    DateTime?
  reviewedById  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  assignment    Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignmentId, userId])
}

model Certificate {
  id            String   @id @default(cuid())
  serialNumber  String   @unique
  userId        String
  courseId      String
  issuedById    String
  issuedAt      DateTime @default(now())
  metadata      Json?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  issuedBy      User     @relation("CertificateIssuer", fields: [issuedById], references: [id], onDelete: Cascade)
}

model AccessGrant {
  id          String      @id @default(cuid())
  userId      String
  courseId    String
  type        AccessType
  source      AccessSource
  startsAt    DateTime    @default(now())
  expiresAt   DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order       Order?

  @@index([userId, courseId])
}

model Order {
  id                String      @id @default(cuid())
  externalId        String      @unique
  provider          String
  userId            String
  courseId          String
  amount            Int
  currency          String      @default("RUB")
  status            OrderStatus @default(PENDING)
  paymentUrl        String?
  accessGrantId     String?     @unique
  rawPayload        Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  accessGrant       AccessGrant? @relation(fields: [accessGrantId], references: [id])

  @@index([userId, courseId])
}

model RatingEvent {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  reason      String
  sourceId    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserRating {
  id          String   @id @default(cuid())
  userId      String   @unique
  points      Int      @default(0)
  level       Int      @default(1)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([points])
}

model EventLog {
  id          String   @id @default(cuid())
  userId      String?
  eventName   String
  payload     Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
}
